generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  CUSTOMER
  SUPER_ADMIN
  STORE_ADMIN
}

enum OrderStatus {
  WAITING_PAYMENT
  WAITING_PAYMENT_CONFIRMATION
  PROCESSING
  SHIPPED
  CONFIRMED
  CANCELLED
}

enum DiscountType {
  PERCENTAGE
  NOMINAL
  BOGO
}

enum VoucherScope {
  PRODUCT
  CART
  SHIPPING
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  phone         String?
  password      String?
  passwordHash  String?
  authProvider  String         @default("credentials")
  role          Role           @default(CUSTOMER)
  isActive      Boolean        @default(true)
  verifiedAt    DateTime?
  avatarUrl     String?
  referralCode  String?        @unique
  referredBy    String?
  storeId       String?
  store         Store?         @relation(fields: [storeId], references: [id])
  addresses     Address[]
  carts         CartItem[]
  orders        Order[]
  voucherUsages VoucherUsage[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Store {
  id        String         @id @default(cuid())
  name      String
  city      String
  latitude  Float
  longitude Float
  radiusKm  Float          @default(10)
  isMain    Boolean        @default(false)
  admins    User[]
  stocks    Inventory[]
  carts     CartItem[]
  orders    Order[]
  discounts Discount[]
  journals  StockJournal[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model Address {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  label         String
  recipientName String?
  phone         String?
  detail        String
  district      String?
  city          String?
  province      String?
  postalCode    String?
  note          String?
  latitude      Float
  longitude     Float
  isPrimary     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ProductCategory {
  id        String    @id @default(cuid())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id          String          @id @default(cuid())
  name        String          @unique
  description String?
  price       Int
  unit        String
  categoryId  String
  category    ProductCategory @relation(fields: [categoryId], references: [id])
  images      ProductImage[]
  stocks      Inventory[]
  carts       CartItem[]
  orderItems  OrderItem[]
  discounts   Discount[]
  journals    StockJournal[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])
  url       String
}

model Inventory {
  id        String   @id @default(cuid())
  storeId   String
  productId String
  store     Store    @relation(fields: [storeId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([storeId, productId])
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  storeId   String
  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
  store     Store    @relation(fields: [storeId], references: [id])
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId, storeId])
}

model StockJournal {
  id        String   @id @default(cuid())
  storeId   String
  productId String
  store     Store    @relation(fields: [storeId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
  change    Int
  note      String
  createdAt DateTime @default(now())
}

model Discount {
  id          String       @id @default(cuid())
  storeId     String
  productId   String?
  store       Store        @relation(fields: [storeId], references: [id])
  product     Product?     @relation(fields: [productId], references: [id])
  title       String
  type        DiscountType
  value       Int
  minSpend    Int?
  maxDiscount Int?
  startsAt    DateTime
  expiresAt   DateTime
  createdAt   DateTime     @default(now())
}

model Voucher {
  id          String         @id @default(cuid())
  code        String         @unique
  title       String
  scope       VoucherScope
  type        DiscountType
  value       Int
  minSpend    Int?
  maxDiscount Int?
  productId   String?
  expiresAt   DateTime
  usages      VoucherUsage[]
  createdAt   DateTime       @default(now())
}

model Order {
  id                String               @id @default(cuid())
  orderNumber       String               @unique
  userId            String
  storeId           String
  addressId         String?
  addressSnapshot   Json?
  deliveryDate      DateTime?
  deliverySlot      String?
  shippingMethod    String?
  shippingProvider  String?
  shippingCost      Int                  @default(0)
  serviceFee        Int                  @default(0)
  discountTotal     Int                  @default(0)
  voucherId         String?
  voucherCode       String?
  paymentMethod     String?
  paymentChannel    String?
  paymentInvoiceUrl String?
  paymentExternalId String?
  trackingNumber    String?
  courierName       String?
  estimatedArrival  DateTime?
  orderNote         String?
  user              User                 @relation(fields: [userId], references: [id])
  store             Store                @relation(fields: [storeId], references: [id])
  status            OrderStatus          @default(WAITING_PAYMENT)
  total             Int
  paymentProofUrl   String?
  paymentDeadline   DateTime?
  items             OrderItem[]
  histories         OrderStatusHistory[]
  voucherUsages     VoucherUsage[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Int
}

model OrderStatusHistory {
  id          String      @id @default(cuid())
  orderId     String
  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status      OrderStatus
  description String?
  location    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([orderId, createdAt])
}

model VoucherUsage {
  id        String   @id @default(cuid())
  voucherId String
  voucher   Voucher  @relation(fields: [voucherId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  orderId   String?
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  code      String
  discount  Int
  createdAt DateTime @default(now())

  @@index([userId, voucherId])
  @@index([orderId])
}
